# newdevjobs — variáveis do FRONTEND (copie para frontend/.env)
# Supabase: Settings → API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=...

# URL da API backend.
# Em dev pode deixar VAZIO (o Vite faz proxy de /api → :3001).
# Em produção, aponte para o serviço da API (ex.: https://newdevjobs-api.onrender.com).
VITE_API_URL=

# Stripe (chave PUBLICÁVEL — pode ir para o cliente)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
