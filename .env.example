# ============================================================
# newdevjobs — variáveis do BACKEND (copie para .env)
# ============================================================

# --- Banco (Supabase Postgres) ---
# Use o POOLER em SESSION MODE (porta 5432) — exigido pelo pg-boss; a conexão
# "direta" (db.<ref>.supabase.co) foi descontinuada. Settings → Database →
# Connection string → "Session pooler". Senha com @ → %40 na URL. Usuário = postgres.<ref>.
DATABASE_URL=postgresql://postgres.SEU-PROJETO:SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# --- Supabase Auth / Storage ---
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=...                 # Settings → API → anon public
SUPABASE_SERVICE_ROLE_KEY=...         # Settings → API → service_role (secreta!)
SUPABASE_STORAGE_BUCKET=cvs           # bucket privado para os currículos

# --- Google OAuth (conectar Gmail para ENVIAR — escopo gmail.send) ---
# (Separado do "login com Google", que é feito pelo Supabase Auth.)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# --- App ---
FRONTEND_URL=http://localhost:5173    # origem permitida no CORS + redirects
PORT=3001
ADMIN_EMAILS=seu@email.com            # emails com acesso de admin (vírgula)

# --- Scraper (Apify) ---
APIFY_TOKEN=apify_api_...
# Contas extras (fallback do crédito grátis ~$5/mês por conta). Opcionais — o
# scraper rotaciona automaticamente quando o crédito de uma esgota. Status/reset
# ficam no painel de admin (aba Estatísticas → Contas Apify).
APIFY_TOKEN_2=
APIFY_TOKEN_3=
APIFY_TOKEN_4=
APIFY_PROFILE_ACTOR_ID=               # LinkedIn Profile Search Scraper (descoberta)
APIFY_POST_ACTOR_ID=buIWk2uOUzTmcLsuB # LinkedIn Post Search Scraper (monitoramento)

# --- Resend (email marketing / campanhas) ---
# Domínio verificado no Resend (SPF/DKIM) para as campanhas caírem na inbox.
RESEND_API_KEY=re_...

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...       # de `stripe listen` (dev) ou do webhook no dashboard (prod)
STRIPE_PRICE_STARTER=price_...        # gerado por: node backend/scripts/stripe-setup.js
STRIPE_PRICE_PRO=price_...
# STRIPE_CURRENCY=brl                 # moeda dos preços criados pelo setup (default brl)

# --- IA — pré-análise do scraper (cadeia de provedores com fallback) ---
# Ordem de tentativa: o 1º que responder vence; se falha/rate-limita, cai no próximo.
# Default groq→openai: Groq é barato/rápido p/ volume; OpenAI preserva saldo como rede.
AI_PROVIDER_ORDER=groq,openai
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=sk-...                 # opcional; só usado como fallback (ou inverta a ordem)
OPENAI_MODEL=gpt-4o-mini
AI_ENABLED=true                       # false desliga a IA (usa só o fallback regex)
AI_MIN_CONFIDENCE=70                  # confiança mínima p/ um post virar vaga
AI_MAX_CALLS_PER_RUN=40               # teto de chamadas por execução do scraper
AI_TIMEOUT_MS=15000

# --- Worker / Dev ---
# SEND_INTERVAL_MS=4000               # acelera o espaçamento de envio em dev
# EMAIL_MODE=mock                     # força envio simulado mesmo com Google configurado
